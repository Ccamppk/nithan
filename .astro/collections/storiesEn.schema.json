{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "author": {
      "type": "string"
    },
    "adapter": {
      "type": "string"
    },
    "ageRange": {
      "type": "string"
    },
    "readingTime": {
      "type": "number"
    },
    "cover": {
      "type": "string"
    },
    "publishedAt": {
      "type": "string",
      "format": "date-time"
    },
    "excerpt": {
      "type": "string"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "category",
    "source",
    "ageRange",
    "readingTime",
    "publishedAt",
    "excerpt"
  ]
}