---
import Base from '../../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import { ui, iconMap } from '../../../i18n';

const t = ui.en;

export async function getStaticPaths() {
  const stories = await getCollection('storiesEn');
  return stories.map(story => ({
    params: { id: story.id },
    props: { story },
  }));
}

const { story } = Astro.props;
const { Content } = await render(story);

// Does this story have a Thai original? (controls hreflang)
const thStories = await getCollection('stories');
const hasTh = thStories.some(s => s.id === story.id);

const siteUrl = Astro.site?.href.replace(/\/$/, '') ?? 'https://nithaan.com';
const storyUrl = `${siteUrl}/en/stories/${story.id}`;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: story.data.title,
  description: story.data.excerpt,
  image: story.data.cover ? new URL(story.data.cover, siteUrl).href : undefined,
  datePublished: story.data.publishedAt.toISOString(),
  author: { '@type': 'Organization', name: story.data.author ?? 'Nithaan' },
  publisher: {
    '@type': 'Organization',
    name: 'Nithaan',
    logo: { '@type': 'ImageObject', url: `${siteUrl}/logo-white.webp` },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': storyUrl },
  inLanguage: 'en',
  genre: story.data.category,
  typicalAgeRange: story.data.ageRange,
  timeRequired: `PT${story.data.readingTime}M`,
};
---
<Base title={story.data.title} description={story.data.excerpt} image={story.data.cover} lang="en" hasAlt={hasTh}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <main class="reader-wrap">
    <header class="reader-header">
      <div class="story-meta" style="margin-bottom:0.8rem;">
        <span class="cat-badge">
          <span class="material-symbols-outlined">{iconMap[story.data.category] ?? 'auto_stories'}</span>
          {story.data.category}
        </span>
      </div>
      <h1 class="reader-title">{story.data.title}</h1>
      <div class="reader-meta">
        <span class="reader-meta-item">
          <span class="material-symbols-outlined">schedule</span> {story.data.readingTime} {t.readingTime}
        </span>
        <span class="reader-meta-item">
          <span class="material-symbols-outlined">child_care</span> {story.data.ageRange}
        </span>
        <span class="reader-meta-item">
          <span class="material-symbols-outlined">menu_book</span> {story.data.source}
        </span>
      </div>
    </header>

    <div class="reader-controls">
      <span class="controls-label">{t.fontSize}:</span>
      <button class="font-btn" id="fontSmall">A</button>
      <button class="font-btn" id="fontMedium" style="font-size:1.1rem;">A</button>
      <button class="font-btn" id="fontLarge" style="font-size:1.3rem;">A</button>
    </div>

    {story.data.cover && (
      <img src={story.data.cover} alt={story.data.title} class="reader-cover" width="1536" height="1024" fetchpriority="high" decoding="async" />
    )}

    <article class="story-content" id="storyContent">
      <Content />
    </article>

    {(story.data.author || story.data.adapter) && (
      <div class="story-credits">
        {story.data.author && (
          <div class="credit-item">
            <span class="material-symbols-outlined">history_edu</span>
            <span><strong>Author</strong> {story.data.author}</span>
          </div>
        )}
        {story.data.adapter && (
          <div class="credit-item">
            <span class="material-symbols-outlined">edit_note</span>
            <span><strong>Adapted by</strong> {story.data.adapter}</span>
          </div>
        )}
      </div>
    )}
  </main>

  <script>
    const content = document.getElementById('storyContent') as HTMLElement;
    const sizes: Record<string, string> = {
      fontSmall: '1rem',
      fontMedium: '1.15rem',
      fontLarge: '1.35rem',
    };
    const saved = localStorage.getItem('nithan-font-size');
    if (saved && content) content.style.fontSize = saved;
    ['fontSmall', 'fontMedium', 'fontLarge'].forEach(id => {
      document.getElementById(id)?.addEventListener('click', () => {
        if (content) {
          content.style.fontSize = sizes[id];
          localStorage.setItem('nithan-font-size', sizes[id]);
        }
      });
    });
  </script>
</Base>
