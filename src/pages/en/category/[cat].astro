---
import Base from '../../../layouts/Base.astro';
import StoryCard from '../../../components/StoryCard.astro';
import { getCollection } from 'astro:content';
import { ui, iconMap, ALL_CATEGORIES_EN } from '../../../i18n';

const t = ui.en;

export async function getStaticPaths() {
  const stories = await getCollection('storiesEn');
  return ALL_CATEGORIES_EN.map(cat => ({
    params: { cat },
    props: { stories: stories.filter(s => s.data.category === cat) },
  }));
}

const { cat } = Astro.params;
const { stories } = Astro.props;
const maxDate = stories.length ? Math.max(...stories.map((s: any) => s.data.publishedAt.valueOf())) : 0;
---
<Base title={`${cat} Stories`} description={`${cat} stories from Nithaan`} lang="en" activeCat={cat}>
  <section class="hero" style="padding-top:3rem; padding-bottom:2rem;">
    <h1 style="font-size:2.2rem; display:flex; align-items:center; justify-content:center; gap:0.5rem;">
      <span class="material-symbols-outlined" style="font-size:2rem;">{iconMap[cat] ?? 'auto_stories'}</span>
      {cat}
    </h1>
    <p style="color: var(--text);">{stories.length > 0 ? `${stories.length} ${t.stories} in this category` : 'Coming soon...'}</p>
  </section>

  <main class="container">
    {stories.length === 0 ? (
      <div style="text-align:center; padding:4rem 1rem;">
        <span class="material-symbols-outlined" style="font-size:4rem; color:var(--purple); display:block; margin-bottom:1rem;">bedtime</span>
        <h2 style="font-family:'Mali',cursive; color:var(--gold); margin-bottom:0.8rem;">{t.noStories}</h2>
        <p style="color:var(--text-muted); margin-bottom:2rem;">{t.noStoriesDesc}</p>
      </div>
    ) : (
      <div class="stories-grid">
        {stories.map((story: any) => (
          <StoryCard
            href={`/en/stories/${story.id}`}
            title={story.data.title}
            category={story.data.category}
            cover={story.data.cover}
            readingTime={story.data.readingTime}
            excerpt={story.data.excerpt}
            ageRange={story.data.ageRange}
            publishedAt={story.data.publishedAt}
            isNew={story.data.publishedAt.valueOf() === maxDate}
            newLabel="New"
            readingTimeLabel={t.readingTime}
          />
        ))}
      </div>
    )}
  </main>
</Base>
