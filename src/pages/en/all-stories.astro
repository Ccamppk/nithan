---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { ui, iconMap } from '../../i18n';

const t = ui.en;
const stories = await getCollection('storiesEn');
const sorted = stories.sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);
---
<Base title="All Stories" description={`All stories from Nithan`} lang="en">
  <main class="container" style="padding-top:2rem; padding-bottom:3rem;">
    <h2 class="section-title">{t.allStories} ({sorted.length} {t.stories})</h2>
    <div class="stories-grid">
      {sorted.map(story => (
        <a href={`/en/stories/${story.id}`} class="story-card">
          <div class="story-cover">
            <span class="material-symbols-outlined">{iconMap[story.data.category] ?? 'auto_stories'}</span>
          </div>
          <div class="story-body">
            <div class="story-meta">
              <span class="cat-badge">{story.data.category}</span>
              <span class="read-time">
                <span class="material-symbols-outlined">schedule</span> {story.data.readingTime} {t.readingTime}
              </span>
            </div>
            <h3 class="story-title">{story.data.title}</h3>
            <p class="story-excerpt">{story.data.excerpt}</p>
            <p class="story-age">
              <span class="material-symbols-outlined">child_care</span> {story.data.ageRange}
            </p>
          </div>
        </a>
      ))}
    </div>
  </main>
</Base>
