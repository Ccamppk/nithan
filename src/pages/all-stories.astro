---
import Base from '../layouts/Base.astro';
import StoryCard from '../components/StoryCard.astro';
import { getCollection } from 'astro:content';

const stories = await getCollection('stories');
const sorted = stories.sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);
const maxDate = sorted[0]?.data.publishedAt.valueOf() ?? 0;
---
<Base title="นิทานทั้งหมด" description="รวมนิทานทุกเรื่องจาก Nithan">
  <main class="container" style="padding-top:2rem; padding-bottom:3rem;">
    <h2 class="section-title">นิทานทั้งหมด ({sorted.length} เรื่อง)</h2>
    <div class="stories-grid">
      {sorted.map(story => (
        <StoryCard
          href={`/stories/${story.id}`}
          title={story.data.title}
          category={story.data.category}
          cover={story.data.cover}
          readingTime={story.data.readingTime}
          excerpt={story.data.excerpt}
          ageRange={story.data.ageRange}
          publishedAt={story.data.publishedAt}
          isNew={story.data.publishedAt.valueOf() === maxDate}
        />
      ))}
    </div>
  </main>
</Base>
