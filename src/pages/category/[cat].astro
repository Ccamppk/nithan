---
import Base from '../../layouts/Base.astro';
import StoryCard from '../../components/StoryCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allCategories = ['สอนใจ', 'แฟนตาซี', 'ผจญภัย', 'นานาชาติ', 'ก่อนนอน'];
  const stories = await getCollection('stories');
  return allCategories.map(cat => ({
    params: { cat },
    props: { stories: stories.filter(s => s.data.category === cat) },
  }));
}

const { cat } = Astro.params;
const { stories: rawStories } = Astro.props;
const stories = rawStories.sort((a: any, b: any) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
const maxDate = stories.length ? stories[0].data.publishedAt.valueOf() : 0;

const iconMap: Record<string, string> = {
  'สอนใจ':    'lightbulb',
  'แฟนตาซี':  'auto_fix_high',
  'ผจญภัย':   'travel_explore',
  'นานาชาติ': 'public',
  'ก่อนนอน':  'bedtime',
};

const catSeo: Record<string, { title: string; description: string; intro: string }> = {
  'ก่อนนอน': {
    title: 'นิทานก่อนนอน สำหรับเด็ก',
    description: `รวมนิทานก่อนนอนสำหรับเด็กภาษาไทย ${stories.length} เรื่อง เนื้อเรื่องอ่อนโยนช่วยให้เด็กผ่อนคลายและหลับง่าย เหมาะสำหรับเด็กอายุ 3-8 ปี อ่านฟรีทุกเรื่องบน Nithaan`,
    intro: 'นิทานก่อนนอนช่วยให้เด็กๆ ผ่อนคลายและเตรียมพร้อมสำหรับการนอนหลับที่ดี เรื่องราวอ่อนโยน ภาษาง่าย เต็มไปด้วยจินตนาการที่พาเด็กๆ ไปสู่โลกแห่งความฝัน เหมาะสำหรับเด็กอายุ 3-8 ปี การอ่านนิทานก่อนนอนร่วมกันยังช่วยสร้างสายสัมพันธ์ที่ดีระหว่างพ่อแม่และลูกอีกด้วย',
  },
  'สอนใจ': {
    title: 'นิทานสอนใจ สำหรับเด็ก',
    description: `รวมนิทานสอนใจสำหรับเด็กภาษาไทย ${stories.length} เรื่อง ปลูกฝังคุณธรรม ความซื่อสัตย์ ความกล้าหาญ และค่านิยมที่ดี เหมาะสำหรับเด็กอายุ 3-12 ปี อ่านฟรีทุกเรื่อง`,
    intro: 'นิทานสอนใจช่วยปลูกฝังคุณธรรมและค่านิยมที่ดีให้กับเด็กๆ ผ่านเรื่องราวที่สนุกและจดจำง่าย ไม่ว่าจะเป็นความซื่อสัตย์ ความกล้าหาญ ความเมตตา หรือการอยู่ร่วมกับผู้อื่น นิทานแต่ละเรื่องมีบทเรียนที่เด็กๆ นำไปใช้ในชีวิตจริงได้',
  },
  'แฟนตาซี': {
    title: 'นิทานแฟนตาซี สำหรับเด็ก',
    description: `รวมนิทานแฟนตาซีสำหรับเด็กภาษาไทย ${stories.length} เรื่อง เรื่องราวจินตนาการ เวทมนตร์ และดินแดนมหัศจรรย์ ช่วยพัฒนาความคิดสร้างสรรค์ เหมาะสำหรับเด็กอายุ 4-12 ปี`,
    intro: 'นิทานแฟนตาซีพาเด็กๆ ออกเดินทางสู่โลกแห่งจินตนาการที่ไม่มีขีดจำกัด พบกับมังกร เวทมนตร์ ดินแดนลึกลับ และตัวละครสุดพิเศษที่หาไม่ได้ในโลกความจริง เรื่องราวเหล่านี้ช่วยพัฒนาความคิดสร้างสรรค์และจินตนาการของเด็กๆ ได้อย่างดีเยี่ยม',
  },
  'ผจญภัย': {
    title: 'นิทานผจญภัย สำหรับเด็ก',
    description: `รวมนิทานผจญภัยสำหรับเด็กภาษาไทย ${stories.length} เรื่อง เรื่องราวตื่นเต้น กล้าหาญ การค้นพบโลกใหม่ สร้างแรงบันดาลใจให้กล้าลองสิ่งใหม่ เหมาะสำหรับเด็กอายุ 5-12 ปี`,
    intro: 'นิทานผจญภัยเต็มไปด้วยความตื่นเต้น การผจญภัย และการเอาชนะความท้าทาย ตัวละครเด็กๆ ที่กล้าหาญพร้อมออกสำรวจโลกกว้าง เรื่องราวเหล่านี้สร้างแรงบันดาลใจให้เด็กๆ กล้าคิด กล้าทำ และไม่ยอมแพ้ต่ออุปสรรค',
  },
  'นานาชาติ': {
    title: 'นิทานนานาชาติ สำหรับเด็ก',
    description: `รวมนิทานนานาชาติสำหรับเด็กภาษาไทย ${stories.length} เรื่อง เรียนรู้วัฒนธรรมและประเพณีจากทั่วโลก เปิดโลกทัศน์ให้กว้างขึ้น เหมาะสำหรับเด็กอายุ 5-12 ปี`,
    intro: 'นิทานนานาชาติพาเด็กๆ เดินทางรอบโลกโดยไม่ต้องออกจากบ้าน เรียนรู้วัฒนธรรม ประเพณี และเรื่องราวของเด็กๆ จากประเทศต่างๆ ทั่วโลก ช่วยเปิดโลกทัศน์และสร้างความเข้าใจในความหลากหลายของมนุษยชาติ',
  },
};

const seo = catSeo[cat] ?? {
  title: `นิทาน${cat} สำหรับเด็ก`,
  description: `รวมนิทาน${cat}สำหรับเด็กภาษาไทย อ่านฟรีทุกเรื่องบน Nithaan`,
  intro: '',
};
---
<Base title={seo.title} description={seo.description} activeCat={cat}>
  <section class="hero" style="padding-top:3rem; padding-bottom:2rem;">
    <div class="hero-stars">
      <span class="material-symbols-outlined">star</span>
      <span class="material-symbols-outlined">auto_awesome</span>
      <span class="material-symbols-outlined">star</span>
    </div>
    <h1 style="font-size:2.2rem; display:flex; align-items:center; justify-content:center; gap:0.5rem;">
      <span class="material-symbols-outlined" style="font-size:2rem;">{iconMap[cat] ?? 'auto_stories'}</span>
      {cat}
    </h1>
    <p style="color: var(--text);">{stories.length > 0 ? `นิทานทั้งหมด ${stories.length} เรื่องในหมวดนี้` : 'กำลังรวบรวมนิทาน...'}</p>
  </section>

  <main class="container">

    {seo.intro && (
      <p class="category-intro">{seo.intro}</p>
    )}

    {stories.length === 0 ? (
      <div style="text-align:center; padding:4rem 1rem;">
        <span class="material-symbols-outlined" style="font-size:4rem; color:var(--purple); display:block; margin-bottom:1rem;">bedtime</span>
        <h2 style="font-family:'Mali',cursive; color:var(--gold); margin-bottom:0.8rem;">
          ยังไม่มีนิทานในหมวดนี้
        </h2>
        <p style="color:var(--text-muted); margin-bottom:2rem;">
          กำลังรวบรวมนิทานหมวด{cat} อยู่นะครับ รอติดตามได้เลย
          <span class="material-symbols-outlined" style="font-size:1rem;vertical-align:middle;">auto_awesome</span>
        </p>
      </div>
    ) : (
      <div class="stories-grid">
        {stories.map((story, i) => (
          <StoryCard
            href={`/stories/${story.id}`}
            title={story.data.title}
            category={story.data.category}
            cover={story.data.cover}
            readingTime={story.data.readingTime}
            excerpt={story.data.excerpt}
            ageRange={story.data.ageRange}
            publishedAt={story.data.publishedAt}
            isNew={story.data.publishedAt.valueOf() === maxDate}
            priority={i < 3}
          />
        ))}
      </div>
    )}
  </main>
</Base>
