---
import '../styles/global.css';
import { ui, type Lang, ALL_CATEGORIES_EN } from '../i18n';

interface Props {
  title: string;
  description?: string;
  image?: string;
  activeCat?: string;
  lang?: Lang;
  /** Whether a counterpart page exists in the other language.
   *  Set to false on pages with no translation so we don't emit
   *  an hreflang pointing at a 404 (Google penalises that). */
  hasAlt?: boolean;
}
const { title, description, image, activeCat, lang = 'th', hasAlt = true } = Astro.props;
const t = ui[lang];
const isEn = lang === 'en';

// Single source of truth: driven by `site` in astro.config.mjs.
// Switch the domain there once and canonical/OG/hreflang all follow.
const siteUrl = Astro.site?.href.replace(/\/$/, '') ?? 'https://nithaan.com';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const ogImage = image
  ? new URL(image, siteUrl).href
  : `${siteUrl}/logo-white.webp`;
const fullTitle = `${title} - Nithaan`;
const metaDescription = description ?? t.siteTagline;
const altLangUrl = isEn
  ? new URL(Astro.url.pathname.replace(/^\/en/, '') || '/', siteUrl).href
  : new URL('/en' + Astro.url.pathname, siteUrl).href;

const ALL_CATEGORIES_TH = ['สอนใจ', 'แฟนตาซี', 'ผจญภัย', 'นานาชาติ', 'ก่อนนอน'];
const cats = isEn ? ALL_CATEGORIES_EN : ALL_CATEGORIES_TH;
const catBase = isEn ? '/en/category/' : '/category/';
const homeUrl = isEn ? '/en/' : '/';
const langSwitchUrl = isEn ? Astro.url.pathname.replace(/^\/en/, '') || '/' : '/en' + Astro.url.pathname;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={metaDescription} />
    <meta name="google-site-verification" content="XzulYr2CVTCUiQsvWC0jjw-8zpsbeVAaj6yjnzP6-aQ" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- hreflang for TH/EN (only emit the opposite language when it exists) -->
    <link rel="alternate" hreflang={isEn ? 'en' : 'th'} href={canonicalUrl} />
    {hasAlt && (
      <link rel="alternate" hreflang={isEn ? 'th' : 'en'} href={altLangUrl} />
    )}
    <link rel="alternate" hreflang="x-default" href={isEn && hasAlt ? altLangUrl : canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Nithaan" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1536" />
    <meta property="og:image:height" content="1024" />
    <meta property="og:locale" content={isEn ? 'en_US' : 'th_TH'} />
    <meta property="og:locale:alternate" content={isEn ? 'th_TH' : 'en_US'} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Google AdSense -->
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-3654679826587904" crossorigin="anonymous"></script>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="512x512" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Fonts load non-render-blocking: fetched in parallel, swapped in once ready. -->
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Mali:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Mali:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap" media="print" onload="this.media='all'" />

    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" media="print" onload="this.media='all'" />

    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Mali:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap" />
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" />
    </noscript>
  </head>
  <body>
    <nav class="navbar">
      <div class="container navbar-inner">
        <a href={homeUrl} class="logo">
          <img src="/logo-white.webp" alt="Nithaan" class="logo-img logo-img--white" />
          <img src="/logo-dark.webp" alt="Nithaan" class="logo-img logo-img--dark" />
        </a>
        <ul class="nav-links">
          {cats.map(cat => (
            <li><a href={`${catBase}${cat}`} class={activeCat === cat ? 'nav-active' : ''}>{cat}</a></li>
          ))}
        </ul>
        <div style="display:flex; align-items:center; gap:0.5rem;">
          <a href={langSwitchUrl} class="lang-btn" aria-label="Switch language">
            {isEn ? 'ไทย' : 'EN'}
          </a>
          <button class="theme-btn" id="themeToggle" aria-label="Toggle theme">
            <span class="material-symbols-outlined">dark_mode</span>
          </button>
        </div>
      </div>
    </nav>

    <slot />

    <footer class="footer">
      <div class="container">
        <p style="display:flex; align-items:center; justify-content:center; gap:0.8rem; margin:0; padding:0; line-height:1;">
          <img src="/logo-white.webp" alt="Nithaan" class="logo-img logo-img--white" style="height:1.2rem;" />
          <img src="/logo-dark.webp" alt="Nithaan" class="logo-img logo-img--dark" style="height:1.2rem;" />
        </p>
        <div class="footer-links">
          <a href={isEn ? '/en/privacy' : '/privacy'}>{t.privacy}</a>
          <span>·</span>
          <a href={isEn ? '/en/terms' : '/terms'}>{t.terms}</a>
          <span>·</span>
          <a href={isEn ? '/en/contact' : '/contact'}>{t.contact}</a>
        </div>
        <p class="footer-copy">{t.copyright}</p>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('themeToggle');
      const body = document.body;

      const saved = localStorage.getItem('nithan-theme');
      if (saved === 'night') {
        body.classList.add('day-mode');
        if (btn) btn.innerHTML = '<span class="material-symbols-outlined">light_mode</span>';
      }

      btn?.addEventListener('click', () => {
        const isNight = body.classList.toggle('day-mode');
        btn.innerHTML = isNight
          ? '<span class="material-symbols-outlined">light_mode</span>'
          : '<span class="material-symbols-outlined">dark_mode</span>';
        localStorage.setItem('nithan-theme', isNight ? 'night' : 'day');
      });
    </script>
  </body>
</html>
